# Public HTTPS hostname. Point this hostname to the Oracle VM public IPv4.
VIZI_API_HOST=api.example.com
ACME_EMAIL=admin@example.com

# Supabase PostgreSQL session pooler connection.
SPRING_DATASOURCE_URL=jdbc:postgresql://your-pooler-host:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=your-pooler-user
SPRING_DATASOURCE_PASSWORD=replace-me

# Browser origins allowed to call the API. Do not use a wildcard in production.
APP_CORS_ALLOWED_ORIGINS=https://vizi.pages.dev

# Backend-only integrations and admin bootstrap.
GEMINI_API_KEY=replace-me
ICONS8_API_KEY=
VIZI_ADMIN_EMAIL=admin@example.com
VIZI_ADMIN_PASSWORD=replace-me
